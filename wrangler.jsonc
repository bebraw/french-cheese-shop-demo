{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "french-cheese-shop-demo",
  "main": "src/worker.ts",
  "compatibility_date": "2026-03-28",
  "preview_urls": true,
  "build": {
    "command": "npm run build:css",
    "watch_dir": "src",
  },
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.css"],
      "fallthrough": true,
    },
  ],
}
